---
permalink: /sitemap.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {%- for page in collections.all %}
  <url>
    <loc>https://logistryx.com{{ page.url }}</loc>
    <lastmod>{{ page.date.toISOString() }}</lastmod>
    <changefreq>{% if page.url == "/" %}daily{% elif "reviews" in page.url or "guides" in page.url or "best-picks" in page.url %}weekly{% else %}monthly{% endif %}</changefreq>
    <priority>{% if page.url == "/" %}1.0{% elif "best-picks" in page.url %}0.9{% elif "reviews" in page.url %}0.8{% elif "guides" in page.url %}0.8{% else %}0.5{% endif %}</priority>
  </url>
  {%- endfor %}
</urlset>
